# Copy to .env for local development. Precedence: env var > .env > built-in default.

# HTTP
HTTP_PORT=8080
SHUTDOWN_TIMEOUT=10s

# Database
# NOTE: docker compose maps Postgres to host port 5433, so for local runs against
# Compose use DB_PORT=5433. Inside the Compose network the app talks to db:5432.
DB_HOST=localhost
DB_PORT=5433
DB_USER=marketd
DB_PASSWORD=marketd
DB_NAME=marketd
DB_SSLMODE=disable

# Logging
LOG_LEVEL=info

# Migrations / seeding
AUTO_MIGRATE=true
SEED=false

# Auction
AUCTION_WINDOW=24h
AUCTION_EXTENSION=5m

# Background workers
SETTLE_INTERVAL=10s

# Oracle price feed
ORACLE_POLL_INTERVAL=30s
ORACLE_TIMEOUT=2s
ORACLE_MAX_RETRIES=2
ORACLE_BACKOFF=100ms
ORACLE_BREAKER_TRIP=3
ORACLE_BREAKER_COOLDOWN=15s
ORACLE_MAX_PRICE=1000000000
ORACLE_MAX_DEVIATION=0
