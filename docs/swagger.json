{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Secure marketplace for trading and auctioning items in Aethoria.\nCommon and Rare items trade via fixed-price listings. Legendary items trade via auctions.",
        "title": "Market Dragon API",
        "contact": {
            "name": "Market Dragon Team"
        },
        "license": {
            "name": "MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/auctions": {
            "get": {
                "description": "List every auction that is currently open for bids.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auctions"
                ],
                "summary": "List active auctions",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.AuctionListResponse"
                        }
                    }
                }
            }
        },
        "/auctions/{id}": {
            "get": {
                "description": "Get one auction and its current highest bid (if any).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auctions"
                ],
                "summary": "Get an auction",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Auction ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.AuctionDetailResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/guilds/{id}/wallet": {
            "get": {
                "description": "Return a guild's wallet balance. Available balance is Total minus Reserved.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "guilds"
                ],
                "summary": "Get a guild wallet",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Guild ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.WalletResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Return 200 while the service is up.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.HealthResponse"
                        }
                    }
                }
            }
        },
        "/items": {
            "get": {
                "description": "List every item with its current validated Oracle price (when available).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "List items",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.ItemListResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Register a new item owned by a guild. The item is not for sale yet. Legendary items are unique (stock is forced to 1).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Register an item",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Item to register",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.CreateItemRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/api.ItemResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}": {
            "get": {
                "description": "Get one item, its live price, and its active offer (fixed-price listing or auction) if any.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Get an item",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.ItemDetailResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}/auction": {
            "post": {
                "description": "Open an auction for a Legendary item. Only one active auction per item is allowed.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Open an auction",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Seller",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.OpenAuctionRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/api.AuctionResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}/bid": {
            "post": {
                "description": "Place a bid on an item's active auction. A new bid must be at least 5% above the current highest bid. Funds are reserved, not debited.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Place a bid",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Bid to place",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.PlaceBidRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/api.BidResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "402": {
                        "description": "Payment Required",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}/bid/{bid_id}": {
            "delete": {
                "description": "Cancel a bid on an item's active auction. You cannot cancel a bid while you are the highest bidder.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Cancel a bid",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Bid ID",
                        "name": "bid_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Bidder",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.CancelBidRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.StatusResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}/buy": {
            "post": {
                "description": "Buy a fixed-price item. Checks the balance and daily cap, moves money, and transfers the item in one transaction.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "Buy an item",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Buyer",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.BuyRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.ListingResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "402": {
                        "description": "Payment Required",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/items/{id}/list": {
            "post": {
                "description": "Offer a Common/Rare item at a fixed price (a limit order). Legendary items must use an auction instead.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "items"
                ],
                "summary": "List an item for sale",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key to make retries safe",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Price and seller",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.ListForSaleRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/api.ListingResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.AuctionDetailResponse": {
            "type": "object",
            "properties": {
                "auction": {
                    "$ref": "#/definitions/api.AuctionResponse"
                },
                "highest_bid": {
                    "$ref": "#/definitions/api.BidResponse"
                }
            }
        },
        "api.AuctionListResponse": {
            "type": "object",
            "properties": {
                "auctions": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.AuctionResponse"
                    }
                }
            }
        },
        "api.AuctionResponse": {
            "type": "object",
            "properties": {
                "ends_at": {
                    "type": "string",
                    "example": "2026-01-02T00:00:00Z"
                },
                "highest_bid_id": {
                    "type": "integer"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "item_id": {
                    "type": "integer",
                    "example": 3
                },
                "seller_guild_id": {
                    "type": "integer",
                    "example": 3
                },
                "starts_at": {
                    "type": "string",
                    "example": "2026-01-01T00:00:00Z"
                },
                "status": {
                    "type": "string",
                    "example": "active"
                },
                "winner_guild_id": {
                    "type": "integer"
                }
            }
        },
        "api.BidResponse": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 1200
                },
                "auction_id": {
                    "type": "integer",
                    "example": 1
                },
                "bidder_guild_id": {
                    "type": "integer",
                    "example": 1
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "status": {
                    "type": "string",
                    "example": "active"
                }
            }
        },
        "api.BuyRequest": {
            "type": "object",
            "required": [
                "buyer_guild_id"
            ],
            "properties": {
                "buyer_guild_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "api.CancelBidRequest": {
            "type": "object",
            "required": [
                "bidder_guild_id"
            ],
            "properties": {
                "bidder_guild_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "api.CreateItemRequest": {
            "type": "object",
            "required": [
                "name",
                "owner_guild_id",
                "tier"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Elven Bow"
                },
                "owner_guild_id": {
                    "type": "integer",
                    "example": 2
                },
                "stock": {
                    "type": "integer",
                    "example": 5
                },
                "tier": {
                    "type": "string",
                    "example": "rare"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "item not found"
                }
            }
        },
        "api.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        },
        "api.ItemDetailResponse": {
            "type": "object",
            "properties": {
                "auction": {
                    "$ref": "#/definitions/api.AuctionResponse"
                },
                "item": {
                    "$ref": "#/definitions/api.ItemResponse"
                },
                "listing": {
                    "$ref": "#/definitions/api.ListingResponse"
                }
            }
        },
        "api.ItemListResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.ItemResponse"
                    }
                }
            }
        },
        "api.ItemResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer",
                    "example": 3
                },
                "name": {
                    "type": "string",
                    "example": "Soul Reaver"
                },
                "owner_guild_id": {
                    "type": "integer",
                    "example": 3
                },
                "price": {
                    "type": "integer",
                    "example": 250000
                },
                "status": {
                    "type": "string",
                    "example": "available"
                },
                "stock": {
                    "type": "integer",
                    "example": 1
                },
                "tier": {
                    "type": "string",
                    "example": "legendary"
                }
            }
        },
        "api.ListForSaleRequest": {
            "type": "object",
            "required": [
                "price",
                "seller_guild_id"
            ],
            "properties": {
                "price": {
                    "type": "integer",
                    "example": 500
                },
                "seller_guild_id": {
                    "type": "integer",
                    "example": 2
                }
            }
        },
        "api.ListingResponse": {
            "type": "object",
            "properties": {
                "buyer_guild_id": {
                    "type": "integer"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "item_id": {
                    "type": "integer",
                    "example": 2
                },
                "price": {
                    "type": "integer",
                    "example": 500
                },
                "seller_guild_id": {
                    "type": "integer",
                    "example": 2
                },
                "status": {
                    "type": "string",
                    "example": "open"
                }
            }
        },
        "api.OpenAuctionRequest": {
            "type": "object",
            "required": [
                "seller_guild_id"
            ],
            "properties": {
                "seller_guild_id": {
                    "type": "integer",
                    "example": 3
                }
            }
        },
        "api.PlaceBidRequest": {
            "type": "object",
            "required": [
                "amount",
                "bidder_guild_id"
            ],
            "properties": {
                "amount": {
                    "type": "integer",
                    "example": 1200
                },
                "bidder_guild_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "api.StatusResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "cancelled"
                }
            }
        },
        "api.WalletResponse": {
            "type": "object",
            "properties": {
                "available": {
                    "type": "integer",
                    "example": 98800
                },
                "guild_id": {
                    "type": "integer",
                    "example": 1
                },
                "reserved": {
                    "type": "integer",
                    "example": 1200
                },
                "total": {
                    "type": "integer",
                    "example": 100000
                }
            }
        }
    },
    "tags": [
        {
            "description": "Register, list, sell, buy, and bid on items",
            "name": "items"
        },
        {
            "description": "Active auctions for Legendary items",
            "name": "auctions"
        },
        {
            "description": "Guild wallets",
            "name": "guilds"
        },
        {
            "description": "Health and diagnostics",
            "name": "system"
        }
    ]
}